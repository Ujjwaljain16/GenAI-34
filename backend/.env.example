# ─────────────────────────────────────────────────────────────────────────────
# Database & Backend
# ─────────────────────────────────────────────────────────────────────────────
# Uses the docker-compose service name 'postgres'
DATABASE_URL="postgresql://Lexis_user:your_password@postgres:5432/Lexis_db?sslmode=disable"
JWT_SECRET="super-secret-key-change-in-production"

# ─────────────────────────────────────────────────────────────────────────────
# Neo4j Config
# ─────────────────────────────────────────────────────────────────────────────
# Uses the docker-compose service name 'neo4j'
NEO4J_URI="bolt://neo4j:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your_neo4j_password"

# ─────────────────────────────────────────────────────────────────────────────
# Gemini
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key from Google AI Studio
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash-lite"

# ─────────────────────────────────────────────────────────────────────────────
# NextAuth (Frontend)
# ─────────────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="super-secret-key-change-in-production"

# ─────────────────────────────────────────────────────────────────────────────
# FastAPI Backend URL (Frontend)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"

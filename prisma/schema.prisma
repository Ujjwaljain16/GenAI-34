generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  passwordHash      String
  avatarUrl         String?
  dailyNewNodeCap   Int      @default(5)
  dailyReminderTime String?
  sessionLengthPref Int      @default(20)
  notifyReminders   Boolean  @default(true)
  notifyDueReviews  Boolean  @default(true)
  notifyProcessing  Boolean  @default(true)
  globalStreak      Int      @default(0)
  lastActiveDate    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  books          Book[]
  userNodeStates UserNodeState[]
  sessions       Session[]
  notifications  Notification[]
}

model Book {
  id          String   @id @default(cuid())
  ownerId     String
  title       String
  author      String?
  sourceFile  String?
  coverUrl    String?
  status      String   @default("uploaded")
  isPublic    Boolean  @default(false)
  bookStreak  Int      @default(0)
  lastStudied String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  nodes          KGNode[]
  sessions       Session[]
  userNodeStates UserNodeState[]
  notifications  Notification[]
}

model KGNode {
  id             String   @id @default(cuid())
  bookId         String
  title          String
  summary        String
  sourceChunks   String
  difficultyTier String   @default("beginner")
  orderIndex     Int      @default(0)
  sectionName    String?
  createdAt      DateTime @default(now())

  book           Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  outgoingEdges  KGEdge[]        @relation("FromNode")
  incomingEdges  KGEdge[]        @relation("ToNode")
  userNodeStates UserNodeState[]
  questions      Question[]
}

model KGEdge {
  id         String @id @default(cuid())
  fromNodeId String
  toNodeId   String
  type       String @default("prerequisite")
  weight     Float  @default(1.0)
  confidence Float  @default(0.5)

  fromNode KGNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   KGNode @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId])
}

model UserNodeState {
  id                String   @id @default(cuid())
  userId            String
  nodeId            String
  bookId            String
  state             String   @default("locked")
  masteryScore      Float    @default(0.0)
  recallStability   Float    @default(1.0)
  recallDifficulty  Float    @default(0.3)
  recallProbability Float    @default(1.0)
  lastReviewed      String?
  nextDue           String?
  lapseCount        Int      @default(0)
  reviewCount       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  node KGNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  book Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
}

model Question {
  id          String   @id @default(cuid())
  nodeId      String
  type        String
  difficulty  String   @default("easy")
  source      String
  body        String
  options     String?
  answer      String?
  explanation String?
  createdAt   DateTime @default(now())

  node KGNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model Session {
  id             String   @id @default(cuid())
  userId         String
  bookId         String
  mode           String
  nodeIds        String
  transcript     String   @default("[]")
  questionsAsked String   @default("[]")
  outcomes       String   @default("[]")
  completedAt    String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  bookId    String?
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book? @relation(fields: [bookId], references: [id], onDelete: Cascade)
}
